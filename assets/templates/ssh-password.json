{
    "Id": "PLATFORM_ID",
    "BackEnd": "Scriptable",
    "Meta": {
        "Author": "Safeguard Custom Platform Toolkit",
        "Description": "SSH-based platform with password authentication for Linux/Unix systems",
        "ScriptVersion": "1.0.0",
        "Last Updated": "YYYY-MM-DD"
    },
    "CheckSystem": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "Port": { "Type": "integer", "Required": false, "DefaultValue": "22" } },
            { "FuncUsername": { "Type": "String", "Required": true } },
            { "FuncPassword": { "Type": "Secret", "Required": true } },
            { "RequestTerminal": { "Type": "boolean", "Required": false, "DefaultValue": "false" } },
            { "PrivilegeElevationCommand": { "Type": "String", "Required": false } }
        ],
        "Do": [
            { "SshConnect": {
                "Address": "%Address%",
                "Port": "%Port%",
                "UserName": "%FuncUsername%",
                "Password": "%FuncPassword%",
                "RequestTerminal": "%RequestTerminal%",
                "ConnectionObjectName": "SshConn"
            } },
            { "SshCommand": {
                "ConnectionObjectName": "SshConn",
                "Command": "echo 'connection_test'",
                "ResponseObjectName": "TestResp"
            } },
            { "Condition": {
                "If": "TestResp.ExitStatus == 0",
                "Then": { "Do": [
                    { "SshDisconnect": { "ConnectionObjectName": "SshConn" } },
                    { "Return": { "Value": true } }
                ] },
                "Else": { "Do": [
                    { "SshDisconnect": { "ConnectionObjectName": "SshConn" } },
                    { "Return": { "Value": false } }
                ] }
            } }
        ]
    },
    "CheckPassword": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "Port": { "Type": "integer", "Required": false, "DefaultValue": "22" } },
            { "AccountUsername": { "Type": "String", "Required": true } },
            { "AccountPassword": { "Type": "Secret", "Required": true } },
            { "RequestTerminal": { "Type": "boolean", "Required": false, "DefaultValue": "false" } }
        ],
        "Do": [
            { "Comment": "Attempt to connect as the target account to verify the password" },
            { "Try": {
                "Do": [
                    { "SshConnect": {
                        "Address": "%Address%",
                        "Port": "%Port%",
                        "UserName": "%AccountUsername%",
                        "Password": "%AccountPassword%",
                        "RequestTerminal": "%RequestTerminal%",
                        "ConnectionObjectName": "SshConn"
                    } },
                    { "SshDisconnect": { "ConnectionObjectName": "SshConn" } },
                    { "Return": { "Value": true } }
                ],
                "Catch": [
                    { "Return": { "Value": false } }
                ]
            } }
        ]
    },
    "ChangePassword": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "Port": { "Type": "integer", "Required": false, "DefaultValue": "22" } },
            { "AccountUsername": { "Type": "String", "Required": true } },
            { "AccountPassword": { "Type": "Secret", "Required": true } },
            { "NewPassword": { "Type": "Secret", "Required": true } },
            { "FuncUsername": { "Type": "String", "Required": true } },
            { "FuncPassword": { "Type": "Secret", "Required": true } },
            { "RequestTerminal": { "Type": "boolean", "Required": false, "DefaultValue": "false" } },
            { "PrivilegeElevationCommand": { "Type": "String", "Required": false, "DefaultValue": "sudo" } }
        ],
        "Do": [
            { "Comment": "Connect as service account (with sudo privileges) to change the target password" },
            { "SshConnect": {
                "Address": "%Address%",
                "Port": "%Port%",
                "UserName": "%FuncUsername%",
                "Password": "%FuncPassword%",
                "RequestTerminal": "%RequestTerminal%",
                "ConnectionObjectName": "SshConn"
            } },
            { "Comment": "Use chpasswd to change the password (requires sudo)" },
            { "SetItem": {
                "Name": "ChangeCmd",
                "Value": "echo '%AccountUsername%:%NewPassword%' | %PrivilegeElevationCommand% chpasswd",
                "IsSecret": true
            } },
            { "SshCommand": {
                "ConnectionObjectName": "SshConn",
                "Command": "%ChangeCmd%",
                "ResponseObjectName": "ChangeResp"
            } },
            { "SshDisconnect": { "ConnectionObjectName": "SshConn" } },
            { "Condition": {
                "If": "ChangeResp.ExitStatus == 0",
                "Then": { "Do": [{ "Return": { "Value": true } }] },
                "Else": { "Do": [{ "Throw": { "Value": "Password change failed (exit code: %{ChangeResp.ExitStatus}%)" } }] }
            } }
        ]
    },
    "DiscoverAccounts": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "Port": { "Type": "integer", "Required": false, "DefaultValue": "22" } },
            { "FuncUsername": { "Type": "String", "Required": true } },
            { "FuncPassword": { "Type": "Secret", "Required": true } },
            { "RequestTerminal": { "Type": "boolean", "Required": false, "DefaultValue": "false" } },
            { "MinUid": { "Type": "integer", "Required": false, "DefaultValue": "1000" } }
        ],
        "Do": [
            { "SshConnect": {
                "Address": "%Address%",
                "Port": "%Port%",
                "UserName": "%FuncUsername%",
                "Password": "%FuncPassword%",
                "RequestTerminal": "%RequestTerminal%",
                "ConnectionObjectName": "SshConn"
            } },
            { "Comment": "List local user accounts with UID >= MinUid (excludes system accounts)" },
            { "SshCommand": {
                "ConnectionObjectName": "SshConn",
                "Command": "awk -F: '$3 >= %MinUid% { print $1 }' /etc/passwd",
                "ResponseObjectName": "ListResp"
            } },
            { "SshDisconnect": { "ConnectionObjectName": "SshConn" } },
            { "Condition": {
                "If": "ListResp.ExitStatus == 0",
                "Then": { "Do": [
                    { "ForEachLine": {
                        "Content": "%{ListResp.Output}%",
                        "ElementName": "username",
                        "Body": {
                            "Do": [
                                { "WriteDiscoveredAccount": { "Name": "%username%" } }
                            ]
                        }
                    } },
                    { "Return": { "Value": true } }
                ] },
                "Else": { "Do": [{ "Throw": { "Value": "Account discovery failed" } }] }
            } }
        ]
    },
    "Functions": []
}
