{
    "Id": "PLATFORM_ID",
    "BackEnd": "Scriptable",
    "Meta": {
        "Author": "Safeguard Custom Platform Toolkit",
        "Description": "REST API platform with OAuth 2.0 Password flow",
        "ScriptVersion": "1.0.0",
        "Last Updated": "YYYY-MM-DD"
    },
    "CheckSystem": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "FuncUsername": { "Type": "String", "Required": true } },
            { "FuncPassword": { "Type": "Secret", "Required": true } },
            { "ClientId": { "Type": "String", "Required": true } },
            { "ClientSecret": { "Type": "Secret", "Required": true } }
        ],
        "Do": [
            { "BaseAddress": { "Address": "https://%Address%" } },
            { "NewHttpRequest": { "ObjectName": "AuthReq" } },
            { "SetItem": {
                "Name": "TokenUrl",
                "Value": "/oauth2/token?grant_type=password&client_id=%ClientId%&client_secret=%ClientSecret%&username=%FuncUsername%&password=%FuncPassword%",
                "IsSecret": true
            } },
            { "Request": {
                "RequestObjectName": "AuthReq",
                "ResponseObjectName": "AuthResp",
                "Verb": "POST",
                "Url": "%TokenUrl%",
                "SubstitutionInUrl": true,
                "IgnoreServerCertAuthentication": true,
                "IsSecret": true,
                "Content": {}
            } },
            { "Condition": {
                "If": "AuthResp.StatusCode == 200",
                "Then": { "Do": [{ "Return": { "Value": true } }] },
                "Else": { "Do": [{ "Return": { "Value": false } }] }
            } }
        ]
    },
    "CheckPassword": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "AccountUsername": { "Type": "String", "Required": true } },
            { "AccountPassword": { "Type": "Secret", "Required": true } },
            { "ClientId": { "Type": "String", "Required": true } },
            { "ClientSecret": { "Type": "Secret", "Required": true } }
        ],
        "Do": [
            { "BaseAddress": { "Address": "https://%Address%" } },
            { "NewHttpRequest": { "ObjectName": "AuthReq" } },
            { "SetItem": {
                "Name": "TokenUrl",
                "Value": "/oauth2/token?grant_type=password&client_id=%ClientId%&client_secret=%ClientSecret%&username=%AccountUsername%&password=%AccountPassword%",
                "IsSecret": true
            } },
            { "Request": {
                "RequestObjectName": "AuthReq",
                "ResponseObjectName": "AuthResp",
                "Verb": "POST",
                "Url": "%TokenUrl%",
                "SubstitutionInUrl": true,
                "IgnoreServerCertAuthentication": true,
                "IsSecret": true,
                "Content": {}
            } },
            { "Condition": {
                "If": "AuthResp.StatusCode == 200",
                "Then": { "Do": [{ "Return": { "Value": true } }] },
                "Else": { "Do": [{ "Return": { "Value": false } }] }
            } }
        ]
    },
    "ChangePassword": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "AccountUsername": { "Type": "String", "Required": true } },
            { "AccountPassword": { "Type": "Secret", "Required": true } },
            { "NewPassword": { "Type": "Secret", "Required": true } },
            { "FuncUsername": { "Type": "String", "Required": true } },
            { "FuncPassword": { "Type": "Secret", "Required": true } },
            { "ClientId": { "Type": "String", "Required": true } },
            { "ClientSecret": { "Type": "Secret", "Required": true } },
            { "ApiVersion": { "Type": "String", "Required": false, "DefaultValue": "v1" } }
        ],
        "Do": [
            { "Comment": "Step 1: Authenticate as service account" },
            { "BaseAddress": { "Address": "https://%Address%" } },
            { "NewHttpRequest": { "ObjectName": "AuthReq" } },
            { "SetItem": {
                "Name": "TokenUrl",
                "Value": "/oauth2/token?grant_type=password&client_id=%ClientId%&client_secret=%ClientSecret%&username=%FuncUsername%&password=%FuncPassword%",
                "IsSecret": true
            } },
            { "Request": {
                "RequestObjectName": "AuthReq",
                "ResponseObjectName": "AuthResp",
                "Verb": "POST",
                "Url": "%TokenUrl%",
                "SubstitutionInUrl": true,
                "IgnoreServerCertAuthentication": true,
                "IsSecret": true,
                "Content": {}
            } },
            { "Condition": {
                "If": "AuthResp.StatusCode == 200",
                "Then": { "Do": [
                    { "Comment": "Step 2: Extract access token" },
                    { "ExtractJsonObject": { "JsonObjectName": "AuthResp", "Name": "AuthJson" } },
                    { "SetItem": { "Name": "BearerToken", "Type": "Secret", "Value": "%{AuthJson.access_token}%" } },

                    { "Comment": "Step 3: Find the user by username" },
                    { "NewHttpRequest": { "ObjectName": "FindReq" } },
                    { "Headers": { "RequestObjectName": "FindReq", "AddHeaders": { "Authorization": "Bearer %BearerToken%" } } },
                    { "Request": {
                        "RequestObjectName": "FindReq",
                        "ResponseObjectName": "FindResp",
                        "Verb": "GET",
                        "Url": "api/%ApiVersion%/users?username=%AccountUsername%",
                        "SubstitutionInUrl": true,
                        "IgnoreServerCertAuthentication": true,
                        "Content": {}
                    } },
                    { "ExtractJsonObject": { "JsonObjectName": "FindResp", "Name": "FindJson" } },

                    { "Comment": "TODO: Extract user ID from FindJson and adjust the URL pattern below" },
                    { "SetItem": { "Name": "UserId", "Value": "%{FindJson.records[0].Id}%" } },

                    { "Comment": "Step 4: Change the password" },
                    { "NewHttpRequest": { "ObjectName": "ChangeReq" } },
                    { "Headers": { "RequestObjectName": "ChangeReq", "AddHeaders": { "Authorization": "Bearer %BearerToken%" } } },
                    { "SetItem": { "Name": "ChangeBody", "Value": { "NewPassword": "%NewPassword%" }, "IsSecret": true } },
                    { "Request": {
                        "RequestObjectName": "ChangeReq",
                        "ResponseObjectName": "ChangeResp",
                        "Verb": "POST",
                        "Url": "api/%ApiVersion%/users/%UserId%/password",
                        "SubstitutionInUrl": true,
                        "IgnoreServerCertAuthentication": true,
                        "IsSecret": true,
                        "Content": {
                            "ContentType": "application/json",
                            "ContentObjectName": "ChangeBody"
                        }
                    } },
                    { "Condition": {
                        "If": "ChangeResp.StatusCode == 200 || ChangeResp.StatusCode == 204",
                        "Then": { "Do": [{ "Return": { "Value": true } }] },
                        "Else": { "Do": [{ "Throw": { "Value": "Password change failed" } }] }
                    } }
                ] },
                "Else": { "Do": [{ "Throw": { "Value": "Service account authentication failed" } }] }
            } }
        ]
    },
    "DiscoverAccounts": {
        "Parameters": [
            { "Address": { "Type": "String", "Required": true } },
            { "FuncUsername": { "Type": "String", "Required": true } },
            { "FuncPassword": { "Type": "Secret", "Required": true } },
            { "ClientId": { "Type": "String", "Required": true } },
            { "ClientSecret": { "Type": "Secret", "Required": true } },
            { "ApiVersion": { "Type": "String", "Required": false, "DefaultValue": "v1" } }
        ],
        "Do": [
            { "BaseAddress": { "Address": "https://%Address%" } },
            { "NewHttpRequest": { "ObjectName": "AuthReq" } },
            { "SetItem": {
                "Name": "TokenUrl",
                "Value": "/oauth2/token?grant_type=password&client_id=%ClientId%&client_secret=%ClientSecret%&username=%FuncUsername%&password=%FuncPassword%",
                "IsSecret": true
            } },
            { "Request": {
                "RequestObjectName": "AuthReq",
                "ResponseObjectName": "AuthResp",
                "Verb": "POST",
                "Url": "%TokenUrl%",
                "SubstitutionInUrl": true,
                "IgnoreServerCertAuthentication": true,
                "IsSecret": true,
                "Content": {}
            } },
            { "Condition": {
                "If": "AuthResp.StatusCode == 200",
                "Then": { "Do": [
                    { "ExtractJsonObject": { "JsonObjectName": "AuthResp", "Name": "AuthJson" } },
                    { "SetItem": { "Name": "BearerToken", "Type": "Secret", "Value": "%{AuthJson.access_token}%" } },
                    { "NewHttpRequest": { "ObjectName": "ListReq" } },
                    { "Headers": { "RequestObjectName": "ListReq", "AddHeaders": { "Authorization": "Bearer %BearerToken%" } } },
                    { "Request": {
                        "RequestObjectName": "ListReq",
                        "ResponseObjectName": "ListResp",
                        "Verb": "GET",
                        "Url": "api/%ApiVersion%/users",
                        "SubstitutionInUrl": true,
                        "IgnoreServerCertAuthentication": true,
                        "Content": {}
                    } },
                    { "ExtractJsonObject": { "JsonObjectName": "ListResp", "Name": "ListJson" } },
                    { "Comment": "TODO: Adjust the collection name and username property below" },
                    { "SetItem": { "Name": "Users", "Value": "%{ListJson.records}%" } },
                    { "ForEach": {
                        "CollectionName": "Users",
                        "ElementName": "user",
                        "Body": {
                            "Do": [
                                { "WriteDiscoveredAccount": { "Name": "%{user.Username}%" } }
                            ]
                        }
                    } },
                    { "Return": { "Value": true } }
                ] },
                "Else": { "Do": [{ "Throw": { "Value": "Authentication failed" } }] }
            } }
        ]
    },
    "Functions": []
}
